{
  "manifest_version": 3,
  "name": "Stay Distance",
  "version": "0.1.0",
  "description": "See driving, cycling, and walking times from your saved places to any booking.com listing. Privacy-first, open-source.",
  "permissions": ["storage", "sidePanel", "activeTab", "tabs"],
  "host_permissions": [
    "https://nominatim.openstreetmap.org/*",
    "https://routing.openstreetmap.de/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Stay Distance — open side panel",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.booking.com/*"],
      "js": ["src/content/index.tsx"],
      "run_at": "document_idle"
    }
  ]
}
